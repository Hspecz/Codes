// SQL Table Query
CREATE TABLE IF NOT EXISTS `streamer_approved_items` (
    `item_id` INT(11) PRIMARY KEY,
    `max_amount` INT(11) NOT NULL DEFAULT 1
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

CREATE TABLE IF NOT EXISTS `discord_verification` (
    `account_id` INT(11) PRIMARY KEY,
    `discord_id` VARCHAR(50) NOT NULL,
    `pin` VARCHAR(10) NOT NULL,
    `is_verified` TINYINT(1) DEFAULT 0
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

CREATE TABLE IF NOT EXISTS `redeem_codes` (
  `code` VARCHAR(50) NOT NULL,
  `item_ids` TEXT NOT NULL,
  `amounts` TEXT NOT NULL,
  `expiration` DATETIME NOT NULL,
  `cooldown_mins` INT NOT NULL DEFAULT 0,
  `announced` TINYINT(1) NOT NULL DEFAULT 0,
  PRIMARY KEY (`code`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

CREATE TABLE IF NOT EXISTS `redeem_claims` (
  `claim_id` INT(11) NOT NULL AUTO_INCREMENT,
  `code` VARCHAR(50) NOT NULL,
  `account_id` INT(11) NOT NULL,
  `ip_address` VARCHAR(50) NOT NULL,
  `claim_date` DATETIME NOT NULL,
  PRIMARY KEY (`claim_id`),
  KEY `code_index` (`code`),
  KEY `account_index` (`account_id`),
  KEY `ip_index` (`ip_address`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

ALTER TABLE `redeem_codes` ADD COLUMN `creator_id` INT(11) NOT NULL DEFAULT 0;

