import discord
from discord.ext import commands, tasks
import mysql.connector
from datetime import datetime

# ==========================================
# CONFIGURATION
# ==========================================
STANDARD_CHANNEL_ID = YOUR_CHANNEL_ID
STREAMER_CHANNEL_ID = YOUR_CHANNEL_ID
VERIFY_CHANNEL_ID = YOUR_CHANNEL_ID

DB_HOST = "127.0.0.1"        
DB_USER = "YOUR_DATABASE_USERNAME"         
DB_PASS = "YOUR_DATABASE_PASSWORD"    
DB_NAME = "YOUR_DATABASE"        

BOT_TOKEN = "YOUR_BOT_TOKEN"

intents = discord.Intents.default()
intents.message_content = True
bot = commands.Bot(command_prefix="!", intents=intents)

def get_db_connection():
    return mysql.connector.connect(
        host=DB_HOST, user=DB_USER, password=DB_PASS, database=DB_NAME
    )

@bot.event
async def on_ready():
    print(f"✅ Bot is online and logged in as {bot.user}")
    check_and_announce_codes.start() # Starts the 10-second auto-scanner

@bot.command()
async def verify(ctx, pin: str):
    if ctx.channel.id != VERIFY_CHANNEL_ID:
        # Try to delete their message so they don't leak their PIN in public chat
        try:
            await ctx.message.delete()
        except:
            pass
        
        warning = await ctx.send(f"❌ {ctx.author.mention}, please use the <#{VERIFY_CHANNEL_ID}> channel to verify your account!")
        await warning.delete(delay=7)
        return
    try:
        db = get_db_connection()
        cursor = db.cursor(dictionary=True)
        
        cursor.execute("SELECT account_id, is_verified FROM discord_verification WHERE pin = %s", (pin,))
        result = cursor.fetchone()

        if not result:
            await ctx.reply("❌ **Invalid PIN.** Please generate a new PIN in-game using `@notify`.")
            return

        if result['is_verified'] == 1:
            await ctx.reply("⚠️ **This PIN has already been used.** Your account is already verified!")
            return

        discord_id = str(ctx.author.id)
        cursor.execute("UPDATE discord_verification SET is_verified = 1, discord_id = %s WHERE pin = %s", (discord_id, pin))
        db.commit()

        await ctx.reply(f"✅ **Verification Successful!** Your Discord account is now securely linked to your game account. You may now claim Streamer Codes!")

    except mysql.connector.Error as err:
        await ctx.reply("Database Error. Please contact an admin.")
        print(f"DB Error: {err}")
    finally:
        if 'db' in locals() and db.is_connected():
            cursor.close()
            db.close()

@tasks.loop(seconds=10)
async def check_and_announce_codes():
    try:
        db = get_db_connection()
        cursor = db.cursor(dictionary=True)
        cursor.execute("SELECT code, item_ids, expiration, cooldown_mins FROM redeem_codes WHERE announced = 0")
        new_codes = cursor.fetchall()
        now = datetime.now()

        for row in new_codes:
            code = row['code']
            exp_datetime = row['expiration']
            expires_str = exp_datetime.strftime('%Y-%m-%d %H:%M')
            cooldown = row['cooldown_mins']
            is_expired = exp_datetime < now
            status_tag = "🔴 **[EXPIRED]**" if is_expired else "🟢 **[ACTIVE]**"

            if code.startswith("LINK_"):
                char_name = code.replace("LINK_", "")
                stream_url = row['item_ids']
                channel = bot.get_channel(STREAMER_CHANNEL_ID)
                msg = f"🎥 **{char_name} has started streaming LunarRO!** 🎥\n\nPlease visit {stream_url}\n*Viewer codes will be dropped in chat!*"
            
            elif cooldown > 0:
                channel = bot.get_channel(STREAMER_CHANNEL_ID)
                msg = f"📺 **STREAMER REWARD CODE!** {status_tag}\n\n**Code:** `{code}`\n**Type:** Reusable (Cooldown: {cooldown} Mins)\n**Expires:** {expires_str}\n\n"
                if not is_expired: msg += f"👉 *Use `@redeem {code}` in-game! (Must be `@notify` verified)*"
                else: msg += f"❌ *This code has expired.*"

            else:
                channel = bot.get_channel(STANDARD_CHANNEL_ID)
                msg = f"🎁 **STANDARD REWARD CODE!** {status_tag}\n\n**Code:** `{code}`\n**Type:** One-Time Use per Account\n**Expires:** {expires_str}\n\n"
                if not is_expired: msg += f"👉 *Hurry and claim using `@redeem {code}`!*"
                else: msg += f"❌ *This code has expired.*"

            if channel:
                await channel.send(msg)
                update_cursor = db.cursor()
                update_cursor.execute("UPDATE redeem_codes SET announced = 1 WHERE code = %s", (code,))
                db.commit()

    except Exception as e:
        print(f"Error in scanner: {e}")
    finally:
        if 'db' in locals() and db.is_connected():
            cursor.close()
            db.close()

if __name__ == "__main__":
    bot.run(BOT_TOKEN)
	
