		}
	} else {
		mes "[Lixiss Dorcan]";
		mes "Hello! I manage the reward distributions.";
		mes "Type ^0000FF@redeem <code>^000000 to claim a code!";
		mes "Type ^FF0000@notify^000000 to verify your Discord account!";
		close;
	}

OnNotifyCommand:
	.@acc_id = getcharid(3);
	query_sql("SELECT `is_verified`, `pin` FROM `discord_verification` WHERE `account_id` = " + .@acc_id, .@is_verified, .@pin$);
	
	if (.@is_verified) {
		dispbottom "Your account is already verified with Discord!";
		end;
	}
	
	if (.@pin$ != "") {
		dispbottom "You are not verified yet. Your verification PIN is: " + .@pin$;
		dispbottom "Please provide this PIN to our Discord bot.";
		end;
	}

	.@newpin$ = rand(1000, 9999) + "";
	query_sql("REPLACE INTO `discord_verification` (`account_id`, `discord_id`, `pin`, `is_verified`) VALUES ("+.@acc_id+", '', '"+.@newpin$+"', 0)");
	dispbottom "Your new Discord verification PIN is: " + .@newpin$;
	dispbottom "Please provide this PIN to our Discord bot to get verified.";
	end;

OnStreamCommand:
	.@code$ = escape_sql(.@atcmd_parameters$);
	if (.@code$ == "") {
		dispbottom "Usage: @redeem <code>";
		end;
	}
	.@acc_id = getcharid(3);

	if (!query_sql("SELECT `item_ids`, `amounts`, `cooldown_mins` FROM `redeem_codes` WHERE `code` = '"+.@code$+"' AND `code` NOT LIKE 'LINK_%' AND `expiration` > NOW()", .@item_ids_str$, .@amounts_str$, .@cooldown)) {
		dispbottom "This code is either invalid or has already expired.";
		end;
	}

	if (.@cooldown > 0) {
		query_sql("SELECT `is_verified` FROM `discord_verification` WHERE `account_id` = " + .@acc_id, .@ver);
		if (!.@ver) {
			dispbottom "Error: You must verify your Discord account using @notify before you can claim Streamer codes.";
			end;
		}
	}

	query_sql("SELECT `last_ip` FROM `login` WHERE `account_id` = " + .@acc_id, .@ip$);
	.@ip_safe$ = escape_sql(.@ip$);

	if (.@cooldown == 0) {
		if (query_sql("SELECT 1 FROM `redeem_claims` WHERE `code` = '"+.@code$+"' AND (`account_id` = " + .@acc_id + " OR `ip_address` = '"+.@ip_safe$+"') LIMIT 1", .@dummy)) {
			dispbottom "This code has already been claimed.";
			end;
		}
	} else {
		if (query_sql("SELECT UNIX_TIMESTAMP(`claim_date`) FROM `redeem_claims` WHERE `code` = '"+.@code$+"' AND (`account_id` = " + .@acc_id + " OR `ip_address` = '"+.@ip_safe$+"') ORDER BY `claim_date` DESC LIMIT 1", .@last_claim_time)) {
			.@next_claim_time = .@last_claim_time + (.@cooldown * 60);
			if (gettimetick(2) < .@next_claim_time) {
				.@rem_mins = (.@next_claim_time - gettimetick(2)) / 60;
				dispbottom "Cooldown active! You must wait " + .@rem_mins + " more minutes before claiming this code again.";
				end;
			}
		}
	}

	explode(.@item_arr$, .@item_ids_str$, ",");
	explode(.@amt_arr$, .@amounts_str$, ",");

	.@weight_fail = 0;
	for (.@i = 0; .@i < getarraysize(.@item_arr$); .@i++) {
		if (checkweight(atoi(.@item_arr$[.@i]), atoi(.@amt_arr$[.@i])) == 0) {
			.@weight_fail = 1;
		}
	}
	if (.@weight_fail) {
		dispbottom "Warning: You do not have enough inventory space/weight. Please make room.";
		end;
	}

	for (.@i = 0; .@i < getarraysize(.@item_arr$); .@i++) {
		if (atoi(.@item_arr$[.@i]) > 0) {
			getitem atoi(.@item_arr$[.@i]), atoi(.@amt_arr$[.@i]);
		}
	}

	query_sql("INSERT INTO `redeem_claims` (`code`, `account_id`, `ip_address`, `claim_date`) VALUES ('"+.@code$+"', " + .@acc_id + ", '"+.@ip_safe$+"', NOW())");

	dispbottom "Success! Your reward bundle has been added to your inventory.";
	end;

L_AdminCreate:
	mes "[Admin Code Creator]";
	mes "Enter the exact code you want to create (e.g., NEWYEAR26):";
	input .@new_code$;
	.@new_code$ = escape_sql(.@new_code$);

	if (query_sql("SELECT 1 FROM `redeem_codes` WHERE `code` = '"+.@new_code$+"'", .@dummy)) {
		mes "^FF0000Error: That code already exists!^000000";
		close;
	}

	set .@items_str$, ""; set .@amts_str$, ""; set .@item_count, 0;

L_AddItemLoop:
	next;
	mes "[Admin Code Creator]";
	mes "Items loaded: ^0055FF" + .@item_count + "^000000";
	mes "Enter ^0000FFItem ID^000000 (Type 0 to finish):";
	input .@new_item;

	if (.@new_item == 0) {
		if (.@item_count == 0) { mes "Must add at least 1 item!"; goto L_AddItemLoop; }
		goto L_FinishCode;
	}
	if (getitemname(.@new_item) == "null") { mes "Invalid Item ID."; goto L_AddItemLoop; }

	next;
	mes "Enter Amount of ["+getitemname(.@new_item)+"]:";
	input .@new_amt;
	if (.@new_amt <= 0) goto L_AddItemLoop;

	if (.@item_count > 0) { .@items_str$ += ","; .@amts_str$ += ","; }
	.@items_str$ += .@new_item; .@amts_str$ += .@new_amt; .@item_count++;
	mes "Added!"; goto L_AddItemLoop;

L_FinishCode:
	mes "DAYS until expiration? (0 for hours)";
	input .@days;
	if (.@days == 0) {
		next; mes "HOURS until expiration?"; input .@hours;
		.@time_str$ = "INTERVAL " + .@hours + " HOUR";
	} else {
		.@time_str$ = "INTERVAL " + .@days + " DAY";
	}

	query_sql("INSERT INTO `redeem_codes` (`code`, `item_ids`, `amounts`, `expiration`, `cooldown_mins`, `announced`) VALUES ('"+.@new_code$+"', '"+.@items_str$+"', '"+.@amts_str$+"', DATE_ADD(NOW(), " + .@time_str$ + "), 0, 0)");

	next;
	mes "Standard Code Created: ^0000FF" + .@new_code$ + "^000000";
	close;

L_AdminViewCodes:
	mes "[Active Codes]";
	.@count = query_sql("SELECT `code`, DATE_FORMAT(`expiration`, '%Y-%m-%d %H:%i'), `cooldown_mins` FROM `redeem_codes` WHERE `expiration` > NOW() AND `code` NOT LIKE 'LINK_%' ORDER BY `expiration` ASC", .@code_list$, .@exp_list$, .@cd_list);
	if (.@count == 0) mes "No active codes.";
	for (.@i = 0; .@i < .@count; .@i++) {
		if (.@cd_list[.@i] > 0) mes "^0055FF" + .@code_list$[.@i] + "^000000 | Exp: ^FF0000" + .@exp_list$[.@i] + "^000000 | CD: " + .@cd_list[.@i] + "m";
		else mes "^0055FF" + .@code_list$[.@i] + "^000000 | Exp: ^FF0000" + .@exp_list$[.@i] + "^000000 | One-Time";
		if ((.@i + 1) % 15 == 0 && (.@i + 1) < .@count) { next; mes "---"; }
	}
	close;

OnInit:
	bindatcmd "redeem", strnpcinfo(0) + "::OnStreamCommand";
	bindatcmd "notify", strnpcinfo(0) + "::OnNotifyCommand"; // Binds verification
	initnpctimer;
	end;

OnTimer3000:
	showscript("Admin Code Generator"); 
	setnpctimer 0;
	end;
}

